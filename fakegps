    set)
        if [ -z "$2" ] || [ -z "$3" ]; then
            echo "用法: set <坐标>"
            exit 1
        fi
        check_device
        echo "📍 设置虚拟定位: 纬度=$2 经度=$3"
        $PM developer dvt simulate-location set -- "$2" "$3"
        ;;
    tiananmen|guomao|wangjing|shanghai|shenzhen|paris|newyork|tokyo|london)
        check_device
        read lat lon name <<< $(get_coords "$1")
        echo "📍 设置虚拟定位: $name ($lat, $lon)"
        $PM developer dvt simulate-location set -- "$lat" "$lon"
        ;;
    play)
        if [ -z "$2" ]; then
            echo "用法: play <文件.gpx>"
            exit 1
        fi
        check_device
        echo "🏃 播放轨迹: $2"
        $PM developer dvt simulate-location play "$2"
        ;;
    clear)
        check_device
        # 发送 clear 命令并基于返回码判定是否成功（pymobiledevice3 无 get 命令）
        $PM developer dvt simulate-location clear
        rc=$?
        LOGFILE="$HOME/fakegps-clear.log"
        echo "$(date +%Y-%m-%dT%H:%M:%S) clear exit_code=$rc" >> "$LOGFILE"
        if [ "$rc" -ne 0 ]; then
            echo "❌ clear 命令执行失败 (code $rc)。请确认 tunneld 并重试：sudo python3 -m pymobiledevice3 remote tunneld" >&2
            echo "清除失败，详见日志: $LOGFILE" >&2
            exit $rc
        fi

        # 视为已下发恢复命令；建议用户在设备上验证或稍等片刻
        echo "✅ clear 命令已下发（请稍候在设备上验证是否已恢复真实定位）。详见日志: $LOGFILE"
        ;;
    list)
        echo "📱 已连接设备:"
        list_devices | while IFS='|' read id name ver; do
            echo "  $name (iOS $ver)"
        done
        ;;
    add)
        if [ -z "$2" ] || [ -z "$3" ] || [ -z "$4" ]; then
            echo "用法: add <名称> <坐标>"
            echo "示例: ./fakegps add myhome 39.9 116.3"
            exit 1
        fi
        name="$2"; lat="$3"; lng="$4"
        read wlat wlng <<< $(gcj02_to_wgs84 "$lat" "$lng")
        touch "$CONF"
        sed -i '' "/^CUSTOM_${name}=/d" "$CONF"
        echo "CUSTOM_${name}=\"${wlat} ${wlng}\"" >> "$CONF"
        echo "✅ 已添加: $name ($wlat, $wlng)"
        ;;
    remove)
        if [ -z "$2" ]; then
            echo "用法: remove <名称>"
            exit 1
        fi
        if [ -f "$CONF" ] && grep -q "^CUSTOM_${2}=" "$CONF"; then
            sed -i '' "/^CUSTOM_${2}=/d" "$CONF"
            echo "✅ 已删除: $2"
        else
            echo "❌ 未找到自定义地点: $2"
        fi
        ;;
    places)
        echo "内置地点:"
        for p in tiananmen guomao wangjing shanghai shenzhen paris newyork tokyo london; do
            read lat lon name <<< $(get_coords "$p")
            printf "  %-10s %-10s (%s, %s)\n" "$p" "$name" "$lat" "$lon"
        done
        if [ -f "$CONF" ] && grep -q "^CUSTOM_" "$CONF" 2>/dev/null; then
            echo ""
            echo "自定义地点:"
            grep "^CUSTOM_" "$CONF" | while IFS='=' read key val; do
                val=$(echo "$val" | tr -d '"')
                name=$(echo "$key" | sed 's/CUSTOM_//')
                lat=$(echo "$val" | cut -d' ' -f1)
                lng=$(echo "$val" | cut -d' ' -f2)
                printf "  %-10s (%s, %s)\n" "$name" "$lat" "$lng"
            done
        fi
        ;;
    *)
        # 无参数时进入交互模式
        if [ -z "$1" ]; then
            show_help
            echo ""
            while true; do
                if [ "$AUTO_CONFIRM" = "1" ]; then
                    cmd="help"
                    args=""
                else
                    read -p "fakegps> " cmd args
                fi
                # 去掉 / 前缀
                cmd="${cmd#/}"

                # 去掉 / 前缀
                cmd="${cmd#/}"
                case "$cmd" in
                    exit|quit|q)
                        echo "已退出"
                        break
                        ;;
                    commands)
                        echo "内置地点: tiananmen guomao wangjing shanghai shenzhen paris newyork tokyo london"
                        echo "命令: /set /map /clear /places /add /remove /play /list /commands /exit /help"
                        ;;
                    help|h)
                        show_help
                        ;;
                    "")
                        ;;
                    *)
                        "$SCRIPT_DIR/fakegps" $cmd $args
                        ;;
                esac
            done
        else
            show_help
        fi
        ;;
esac
