});

function gcj02ToWgs84(lat, lng) {
  // Accurate GCJ-02 -> WGS-84 conversion (iterative approximation)
  var a = 6378245.0, ee = 0.00669342162296594323;
  function transformLat(x, y) {
    var ret = -100.0 + 2.0 * x + 3.0 * y + 0.2 * y * y + 0.1 * x * y + 0.2 * Math.sqrt(Math.abs(x));
    ret += (20.0 * Math.sin(6.0 * x * Math.PI) + 20.0 * Math.sin(2.0 * x * Math.PI)) * 2.0 / 3.0;
    ret += (20.0 * Math.sin(y * Math.PI) + 40.0 * Math.sin(y / 3.0 * Math.PI)) * 2.0 / 3.0;
    ret += (160.0 * Math.sin(y / 12.0 * Math.PI) + 320 * Math.sin(y * Math.PI / 30.0)) * 2.0 / 3.0;
    return ret;
  }
  function transformLng(x, y) {
    var ret = 300.0 + x + 2.0 * y + 0.1 * x * x + 0.1 * x * y + 0.1 * Math.sqrt(Math.abs(x));
    ret += (20.0 * Math.sin(6.0 * x * Math.PI) + 20.0 * Math.sin(2.0 * x * Math.PI)) * 2.0 / 3.0;
    ret += (20.0 * Math.sin(x * Math.PI) + 40.0 * Math.sin(x / 3.0 * Math.PI)) * 2.0 / 3.0;
    ret += (150.0 * Math.sin(x / 12.0 * Math.PI) + 300.0 * Math.sin(x / 30.0 * Math.PI)) * 2.0 / 3.0;
    return ret;
  }

  function delta(wgLat, wgLng) {
    var dLat = transformLat(wgLng - 105.0, wgLat - 35.0);
    var dLng = transformLng(wgLng - 105.0, wgLat - 35.0);
    var radLat = wgLat / 180.0 * Math.PI;
    var magic = Math.sin(radLat);
    magic = 1 - ee * magic * magic;
    var sqrtMagic = Math.sqrt(magic);
    dLat = (dLat * 180.0) / ((a * (1 - ee)) / (magic * sqrtMagic) * Math.PI);
    dLng = (dLng * 180.0) / (a / sqrtMagic * Math.cos(radLat) * Math.PI);
    return [dLat, dLng];
  }

  // iterate to approximate WGS-84 from GCJ-02
  var threshold = 1e-6;
  var d = delta(lat, lng);
  var wgsLat = lat - d[0];
  var wgsLng = lng - d[1];
  for (var i = 0; i < 10; i++) {
    var d2 = delta(wgsLat, wgsLng);
    var latTmp = lat - d2[0];
    var lngTmp = lng - d2[1];
    if (Math.abs(latTmp - wgsLat) < threshold && Math.abs(lngTmp - wgsLng) < threshold) {
      wgsLat = latTmp; wgsLng = lngTmp; break;
    }
    wgsLat = latTmp; wgsLng = lngTmp;
  }
  return [parseFloat(wgsLat), parseFloat(wgsLng)];
}

var map = L.map('map', { zoomControl: false }).setView([39.9087, 116.3975], 13);
L.control.zoom({ position: 'bottomleft' }).addTo(map);
L.tileLayer('https://webrd0{s}.is.autonavi.com/appmaptile?lang=zh_cn&size=1&scale=1&style=8&x={x}&y={y}&z={z}', {
  subdomains: ['1','2','3','4'], attribution: '© 高德地图'
}).addTo(map);

map.on('click', function(e) {
  var result = gcj02ToWgs84(e.latlng.lat, e.latlng.lng);
  selectedLat = result[0].toFixed(5);
  selectedLng = result[1].toFixed(5);
  if (marker) map.removeLayer(marker);
  marker = L.marker([e.latlng.lat, e.latlng.lng]).addTo(map);
  document.getElementById('coords').innerHTML = '纬度: <span>'+selectedLat+'</span><br>经度: <span>'+selectedLng+'</span>';
  document.getElementById('copyBtn').disabled = false;
});

function goTo(lat, lng, name) {
  var result = gcj02ToWgs84(lat, lng);
  selectedLat = result[0].toFixed(5);
  selectedLng = result[1].toFixed(5);
  map.setView([lat, lng], 15);
  if (marker) map.removeLayer(marker);
  marker = L.marker([lat, lng]).addTo(map).bindPopup(name).openPopup();
  document.getElementById('coords').innerHTML = '纬度: <span>'+selectedLat+'</span><br>经度: <span>'+selectedLng+'</span>';
  document.getElementById('copyBtn').disabled = false;
}

function getCmd() { return 'set ' + selectedLat + ' ' + selectedLng; }

function copyCmd() {
  navigator.clipboard.writeText(getCmd()).then(function() {
    showToast('已复制: ' + getCmd());
  });
}

function clearLocation() {
  navigator.clipboard.writeText('clear').then(function() {
    showToast('已复制: clear');
  });
}

function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function() { t.classList.remove('show'); }, 2000);
}

// 搜索功能（高德 REST API）
// 处理 IME（中文输入法）并支持回车与搜索按钮
(function(){
  var input = document.getElementById('search');
  var composing = false;
  input.addEventListener('compositionstart', function(){ composing = true; });
  input.addEventListener('compositionend', function(){ composing = false; });
  function doSearchFromInput(){
    var val = input.value.trim();
    if(!val) return;
    var coordMatch = val.match(/^(-?\d+(?:\.\d+)?)[,\s]+(-?\d+(?:\.\d+)?)$/);
    if (coordMatch) { goTo(parseFloat(coordMatch[1]), parseFloat(coordMatch[2]), '自定义位置'); return; }
    // load AMap key from localStorage; if missing, prompt the user to enter it
    var amapKey = localStorage.getItem('AMAP_KEY') || '';    
    // 如果没有配置 AMap Key，搜索直接报错并提示用户在界面顶部输入保存
    if (!amapKey) {
      showToast('未配置 AMap Key，请先在页面顶部输入并保存');
      return;
    }

    if (amapKey && amapKey !== 'REPLACE_WITH_YOUR_AMAP_KEY') {
      fetch('https://restapi.amap.com/v3/place/text?key=' + amapKey + '&keywords=' + encodeURIComponent(val) + '&output=json')
        .then(function(r){ return r.json(); })
        .then(function(data){ if (data.pois && data.pois.length>0){ var poi=data.pois[0]; var loc=poi.location.split(','); goTo(parseFloat(loc[1]), parseFloat(loc[0]), poi.name); } else showToast('未找到该地点'); })
        .catch(function(){ showToast('搜索失败'); });
    } else {
      // try direct fetch first with timeout
      const nominatimUrl = 'https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(val) + '&accept-language=zh-CN&limit=1';
      const fetchWithTimeout = (url, t=7000) => {
        return Promise.race([fetch(url), new Promise((_, rej)=>setTimeout(()=>rej(new Error('timeout')), t))]);
      };
      fetchWithTimeout(nominatimUrl,7000)
        .then(function(r){ if(!r.ok) throw new Error('bad-response'); return r.json(); })
        .then(function(data){ if (data && data.length>0){ var item=data[0]; goTo(parseFloat(item.lat), parseFloat(item.lon), item.display_name); } else showToast('未找到匹配地点或坐标格式不正确'); })
        .catch(function(){
          // fallback: use public CORS proxy (AllOrigins) to bypass network/file origin issues
          const proxy = 'https://api.allorigins.win/raw?url=' + encodeURIComponent(nominatimUrl);
          fetchWithTimeout(proxy,7000)
            .then(function(r){ if(!r.ok) throw new Error('proxy-bad'); return r.json(); })
            .then(function(data){ if (data && data.length>0){ var item=data[0]; goTo(parseFloat(item.lat), parseFloat(item.lon), item.display_name); } else showToast('未找到匹配地点或坐标格式不正确'); })
            .catch(function(err){ console.error('geocode failed',err); showToast('搜索失败（请检查网络或使用 API key）'); });
        });
    }
  }
  input.addEventListener('keydown', function(e){ if(e.key === 'Enter' && !composing){ doSearchFromInput(); } });
  // also allow pressing Ctrl+Enter or clicking Enter on virtual keyboards
  input.addEventListener('keyup', function(e){ if((e.key === 'Enter' || e.keyCode===13) && !composing){ /* noop handled in keydown */ } });
  // don't insert extra button (it interferes with Enter/IME). rely on Enter key and existing UI
})();
