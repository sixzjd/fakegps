list_devices() {
    python3 -c "
import subprocess, json
r = subprocess.run(['python3', '-m', 'pymobiledevice3', 'usbmux', 'list'],
                   capture_output=True, text=True)
try:
    raw = r.stdout
    if 'warnings.warn' in raw:
        lines = [l for l in raw.split('\n') if l.strip().startswith('[') or l.strip().startswith('{') or l.strip().startswith(']')]
        raw = '\n'.join(lines)
    for d in json.loads(raw):
        print(d.get('Identifier','') + '|' + d.get('DeviceName','') + '|' + d.get('ProductVersion',''))
except:
    pass
" 2>/dev/null
}

