gcj02_to_wgs84() {
    python3 -c "
import math
lng,lat=$2,$1
a=6378245.0;ee=0.00669342162296594323
def tl(x,y):
 r=-100+2*x+3*y+.2*y*y+.1*x*y+.2*math.sqrt(abs(x))
 r+=(20*math.sin(6*x*math.pi)+20*math.sin(2*x*math.pi))*2/3
 r+=(20*math.sin(y*math.pi)+40*math.sin(y/3*math.pi))*2/3
 r+=(160*math.sin(y/12*math.pi)+320*math.sin(y*math.pi/30))*2/3
 return r
def tg(x,y):
 r=300+x+2*y+.1*x*x+.1*x*y+.1*math.sqrt(abs(x))
 r+=(20*math.sin(6*x*math.pi)+20*math.sin(2*x*math.pi))*2/3
 r+=(20*math.sin(x*math.pi)+40*math.sin(x/3*math.pi))*2/3
 r+=(150*math.sin(x/12*math.pi)+300*math.sin(x/30*math.pi))*2/3
 return r
dlat=tl(lng-105,lat-35);dlng=tg(lng-105,lat-35)
rl=lat/180*math.pi;mg=math.sin(rl);mg=1-ee*mg*mg;sq=math.sqrt(mg)
dlat=(dlat*180)/((a*(1-ee))/(mg*sq)*math.pi)
dlng=(dlng*180)/(a/sq*math.cos(rl)*math.pi)
print(f'{lat*2-(lat+dlat):.5f} {lng*2-(lng+dlng):.5f}')
"
}

check_device() {
    # If tunneld is not running, error immediately and do not attempt to list devices
    if ! check_tunneld; then
        echo "❌ tunneld 未运行。请在另一个终端启动：sudo python3 -m pymobiledevice3 remote tunneld" >&2
        exit 1
    fi

    local count=$(list_devices | wc -l | tr -d ' ')
    if [ "$count" -eq 0 ]; then
        echo "❌ 没有检测到 iPhone，请确认："
        echo "   1. 数据线已连接"
        echo "   2. iPhone 上点击了\"信任此电脑\"并输入密码"
        echo "   3. tunneld 正常运行（参考上方提示）"
        exit 1
    fi
    echo "📱 检测到 $count 台设备"
}

