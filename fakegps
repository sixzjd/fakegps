#!/usr/bin/env bash
# FakeGPS v5.0
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# If script was launched without a TTY (e.g. double-click from Finder), re-open it in Terminal.app interactively
if [ ! -t 1 ]; then
  SCRIPT_PATH="$SCRIPT_DIR/$(basename "$0")"
  # Use AppleScript to open Terminal and run an interactive bash that executes the script
  /usr/bin/osascript <<APPLESCRIPT
  tell application "Terminal"
    activate
    do script "bash -l -i -c '$SCRIPT_PATH'; echo; echo '已退出 fakegps，按回车关闭窗口...'; read -r"
  end tell
APPLESCRIPT
  exit 0
fi
# 完整版
check_tunneld() {
    if pgrep -f "pymobiledevice3 remote tunneld" > /dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

# 完整版（自定义地点 + 坐标转换）

